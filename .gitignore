# Datos persistentes de producción
/data/data.json
/data/security.json

# Archivos cargados desde el panel (los assets ya versionados siguen en Git)
/assets/uploads/*
!/assets/uploads/.htaccess

# Sistema operativo y editores
.DS_Store
Thumbs.db
.idea/
.vscode/
