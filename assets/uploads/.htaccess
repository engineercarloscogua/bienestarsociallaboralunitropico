Options -Indexes

# Prevenir ejecución o acceso directo a scripts en uploads.
<FilesMatch "\.(php|php3|php4|php5|phtml)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_php.c>
  php_flag engine off
</IfModule>
